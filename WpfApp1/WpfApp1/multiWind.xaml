<Window x:Class="WpfApp1.multiWind"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="multiWind" Height="350" Width="600">
    <Grid>
        <DataGrid Name="tableGrid" d:ItemsSource="{d:SampleData ItemCount=10}" Margin="10,39,0,0" HorizontalAlignment="Left" Width="314" Height="259" VerticalAlignment="Top"/>
        <Button Name="reductButt" Content="режим добавления нового" HorizontalAlignment="Left" Margin="329,10,0,0" VerticalAlignment="Top" Height="30" Width="244"/>
        <TextBlock HorizontalAlignment="Left" Margin="329,45,0,0" TextWrapping="Wrap" Text="id:" VerticalAlignment="Top"/>
        <TextBlock Name="idBlock" HorizontalAlignment="Left" Margin="347,45,0,0" TextWrapping="Wrap" Text="new" VerticalAlignment="Top"/>
        <TextBlock HorizontalAlignment="Left" Margin="329,66,0,0" TextWrapping="Wrap" Text="name" VerticalAlignment="Top"/>
        <TextBox Name="nameBox" HorizontalAlignment="Left" Margin="329,87,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="244" Height="34"/>
        <TextBlock Name="eBlock" HorizontalAlignment="Left" Margin="329,126,0,0" TextWrapping="Wrap" Text="email" VerticalAlignment="Top"/>
        <TextBox x:Name="eBox" HorizontalAlignment="Left" Margin="329,147,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="244" Height="23"/>
        <TextBlock x:Name="lBlock" HorizontalAlignment="Left" Margin="329,175,0,0" TextWrapping="Wrap" Text="login" VerticalAlignment="Top"/>
        <TextBox x:Name="lBox" HorizontalAlignment="Left" Margin="329,196,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="244" Height="23"/>
        <TextBlock x:Name="pBlock" HorizontalAlignment="Left" Margin="329,224,0,0" TextWrapping="Wrap" Text="password" VerticalAlignment="Top"/>
        <TextBox x:Name="pBox" HorizontalAlignment="Left" Margin="329,245,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="244" Height="23"/>
        <Button Name="exitButt" Click="exitButt_Click" Content="назад" HorizontalAlignment="Left" Margin="514,278,0,0" VerticalAlignment="Top" Width="59"/>
        <Button x:Name="saveButt" Content="добавить" HorizontalAlignment="Left" Margin="450,278,0,0" VerticalAlignment="Top" Width="59"/>
        <TextBlock Name="typeBlock" HorizontalAlignment="Left" Margin="10,10,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top"/>

    </Grid>
</Window>
