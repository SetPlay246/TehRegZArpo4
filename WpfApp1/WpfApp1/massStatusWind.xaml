<Window x:Class="WpfApp1.massStatusWind"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="massStatusWind" Height="450" Width="800">
    <Grid>
        <DataGrid Name="massGrid" SelectionChanged="massGrid_SelectionChanged" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="10,10,30,83" IsReadOnly="True" SelectionMode="Extended" SelectionUnit="FullRow"/>
        <TextBlock Name="selectedIdis" HorizontalAlignment="Left" Margin="10,356,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top"/>
        <Button Content="изменить статус" Name="updateButt" Click="updateButt_Click" HorizontalAlignment="Left" Margin="552,0,0,47" Width="114" Height="31" VerticalAlignment="Bottom"/>
        <Button Content="назад" x:Name="exitButt" Click="exitButt_Click" HorizontalAlignment="Left" Margin="671,0,0,47" Width="99" Height="31" VerticalAlignment="Bottom"/>
        <ComboBox Name="statusCombo" HorizontalAlignment="Left" Margin="412,0,0,47" VerticalAlignment="Bottom" Width="135" Height="31"/>
        <Button Content="обновить" Name="refreshButt" Click="refreshButt_Click" HorizontalAlignment="Left" Margin="10,0,0,47" VerticalAlignment="Bottom" Height="30" Width="69"/>

    </Grid>
</Window>
