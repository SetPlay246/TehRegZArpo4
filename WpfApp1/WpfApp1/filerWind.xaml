<Window x:Class="WpfApp1.filerWind"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="filerWind" Height="450" Width="800">
    <Grid>
        <DataGrid Name="fileGrid" SelectionMode="Single" SelectionChanged="fileGrid_SelectionChanged" d:ItemsSource="{d:SampleData ItemCount=5}" IsReadOnly="True" Margin="10,10,65,52"/>
        <Button Content="посмотреть" Name="lookButt" Click="lookButt_Click" HorizontalAlignment="Left" Margin="84,0,0,21" VerticalAlignment="Bottom" Height="26" Width="91"/>
        <Button Name="exitButt" Click="exitButt_Click" Content="назад" Margin="647,0,0,21" VerticalAlignment="Bottom" Height="26" HorizontalAlignment="Left" Width="88"/>
        <Button Content="удалить" Name="dellButt" Click="dellButt_Click" HorizontalAlignment="Left" Margin="180,0,0,21" VerticalAlignment="Bottom" Height="26" Width="91"/>
        <TextBlock HorizontalAlignment="Left" Margin="10,0,0,31" TextWrapping="Wrap" Text="id:" VerticalAlignment="Bottom"/>
        <TextBlock Name="idBlock" HorizontalAlignment="Left" Margin="28,0,0,31" TextWrapping="Wrap" Text="" VerticalAlignment="Bottom"/>
        <Button Content="добавить" Name="addFileButt" Click="addFileButt_Click" HorizontalAlignment="Left" Margin="276,0,0,21" VerticalAlignment="Bottom" Height="26" Width="96"/>
        <Button Name="saveButt" Click="saveButt_Click"  Content="сохранить" Margin="554,0,0,21" VerticalAlignment="Bottom" Height="26" HorizontalAlignment="Left" Width="88"/>
        <TextBlock Name="DBlock" HorizontalAlignment="Left" Margin="377,0,0,21" TextWrapping="Wrap" Text="" Height="26" VerticalAlignment="Bottom" Width="149"/>

    </Grid>
</Window>
