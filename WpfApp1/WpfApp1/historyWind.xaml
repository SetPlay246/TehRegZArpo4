<Window x:Class="WpfApp1.historyWind"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="historyWind" Height="450" Width="600">
    <Grid>
        <DataGrid x:Name="histGrid" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="10,10,27,83" IsReadOnly="True" SelectionMode="Extended" SelectionUnit="FullRow"/>
        <Button Content="назад" Click="Button_Click" HorizontalAlignment="Right" Margin="0,0,27,45" VerticalAlignment="Bottom" Width="48" Height="33"/>
        <Button Content="обновить" Click="Button_Click_1"  HorizontalAlignment="Left" Margin="10,0,0,45" VerticalAlignment="Bottom" Width="69" Height="33"/>
    </Grid>
</Window>
