        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="dashWind" Height="400" Width="400">
    <Grid>
        <DataGrid Name="StatGrid" IsReadOnly="True" SelectionMode="Single" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="0,0,26,62"/>
